# Copy this file to .env and fill in the keys you have.
# Only providers whose key is set will run; others are skipped in the UI.
# You only need TWO keys — one Replicate token unlocks all 4 Replicate models.
PORT=3000

# OpenAI — unlocks: OpenAI gpt-image-1
OPENAI_API_KEY=

# Replicate — ONE token unlocks all of these models:
#   - Replicate FLUX schnell
#   - Replicate FLUX 1.1 pro
#   - Google Imagen 4 (fast)
#   - Ideogram v3 turbo
REPLICATE_API_TOKEN=

# Optional: how many Replicate requests may run at once. Default 1 (sends them
# one at a time to avoid throttling on low-credit accounts). Raise to e.g. 4
# once you have enough paid credit to lift Replicate's burst limit.
REPLICATE_CONCURRENCY=1
